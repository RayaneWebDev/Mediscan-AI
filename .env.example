# ── Backend ────────────────────────────────────────────────────────────────
# Port FastAPI (défaut : 8000)
BACKEND_PORT=8000

# ── Modèles / performance ──────────────────────────────────────────────────
# Threads CPU pour PyTorch (défaut : 1)
MEDISCAN_TORCH_THREADS=1

# ── MongoDB (optionnel — enrichissement des résultats) ────────────────────
# MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/

# ── LLM — Analyse IA (obligatoire pour la fonctionnalité Analyse IA) ──────
# Créer une clé sur https://console.groq.com → API Keys
GROQ_KEY_API=

# ── Chemins (optionnel, valeurs par défaut dans runtime.py) ───────────────
# DATA_DIR=data/roco_train_full
# ARTIFACTS_DIR=artifacts
