{
  "source": {
    "include": ["src"],
    "includePattern": "\\.(js|jsx)$",
    "excludePattern": "node_modules"
  },
  "plugins": ["node_modules/jsdoc-babel", "plugins/markdown"],
  "babel": {
    "presets": ["@babel/preset-env", "@babel/preset-react"]
  },
  "opts": {
    "recurse": true,
    "destination": "../../docs/frontend",
    "template": "node_modules/docdash"
  }
}