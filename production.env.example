# MEDISCAN production environment template
#
# Copy the values into your hosting platform secret manager.
# Do not commit real secrets.

PYTHONPATH=src

# Public frontend origin(s) allowed to call the backend.
MEDISCAN_CORS_ORIGINS=https://your-domain.example

# Upload/download safety limits.
MEDISCAN_MAX_UPLOAD_BYTES=10485760
MEDISCAN_REMOTE_IMAGE_TIMEOUT_SECONDS=15
MEDISCAN_TORCH_THREADS=1

# Public API abuse protection.
MEDISCAN_RATE_LIMIT_WINDOW_SECONDS=60
MEDISCAN_RATE_LIMIT_SEARCH=12
MEDISCAN_RATE_LIMIT_SEARCH_TEXT=20
MEDISCAN_RATE_LIMIT_SEARCH_BY_ID=30
MEDISCAN_RATE_LIMIT_SEARCH_BY_IDS=10
MEDISCAN_RATE_LIMIT_CONCLUSION=5
MEDISCAN_RATE_LIMIT_CONTACT=3
MEDISCAN_SEARCH_CONCURRENCY_LIMIT=2
MEDISCAN_CONCLUSION_CONCURRENCY_LIMIT=2
MEDISCAN_CONTACT_CONCURRENCY_LIMIT=5

# Set to true only behind a trusted reverse proxy that forwards the real client IP.
MEDISCAN_TRUST_PROXY_HEADERS=false

# Optional MongoDB enrichment. Leave MONGO_URI blank to disable.
MONGO_URI=
MEDISCAN_MONGO_SERVER_SELECTION_TIMEOUT_MS=2000
MEDISCAN_MONGO_CONNECT_TIMEOUT_MS=2000

# Optional LLM conclusion generation. The key must stay backend-only.
GROQ_KEY_API=
MEDISCAN_GROQ_MODEL=llama-3.3-70b-versatile
MEDISCAN_MAX_CONCLUSION_RESULTS=6

# Optional contact form SMTP.
MEDISCAN_SMTP_HOST=
MEDISCAN_SMTP_PORT=587
MEDISCAN_SMTP_USERNAME=
MEDISCAN_SMTP_PASSWORD=
MEDISCAN_SMTP_USE_TLS=true
MEDISCAN_SMTP_USE_SSL=false
MEDISCAN_CONTACT_FROM_EMAIL=
MEDISCAN_CONTACT_TO_EMAIL=
MEDISCAN_CONTACT_REPLY_TO_EMAIL=
